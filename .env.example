# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.
# These are read by `fluffy_potato_curriculum.common.config` (pydantic-settings).

# Anthropic — the course anchor provider (Claude Sonnet 4.6).
ANTHROPIC_API_KEY=

# OpenAI — only needed for the lessons that contrast providers.
OPENAI_API_KEY=
