# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.
# These are read by `fluffy_potato_curriculum.common.config` (pydantic-settings).

# Anthropic — the course anchor provider (Claude Sonnet 4.6).
ANTHROPIC_API_KEY=

# OpenAI — only needed for the lessons that contrast providers.
OPENAI_API_KEY=

# --- Local Docker stack (K06) -------------------------------------------------
# The `db` service in compose.yaml falls back to these dev defaults, so you can
# leave them blank for local work. Override only if you need to.
POSTGRES_USER=potato
POSTGRES_PASSWORD=potato
POSTGRES_DB=fluffy_potato
